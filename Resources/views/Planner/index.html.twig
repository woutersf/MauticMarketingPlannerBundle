{% extends '@MauticCore/Default/content.html.twig' %}

{% block mauticContent %}marketingplanner{% endblock %}

{% block headerTitle %}<i class="ri-calendar-line"></i> Marketing Planner{% endblock %}

{% block content %}
<div class="pa-md">

{# ── Toolbar ─────────────────────────────────────────────────────────────── #}
<div class="d-flex ai-center jc-space-between mb-md fw-wrap gap-sm">

    {# View switcher #}
    <div class="btn-group">
        <a href="{{ path('mautic_marketing_planner_index', {view: 'list'}) }}"
           class="btn btn-sm {% if view == 'list' %}btn-primary{% else %}btn-default{% endif %}">
            <i class="ri-list-unordered"></i> List
        </a>
        <a href="{{ path('mautic_marketing_planner_index', {view: 'month', year: year, month: month}) }}"
           class="btn btn-sm {% if view == 'month' %}btn-primary{% else %}btn-default{% endif %}">
            <i class="ri-calendar-2-line"></i> Month
        </a>
        <a href="{{ path('mautic_marketing_planner_index', {view: 'year', year: year}) }}"
           class="btn btn-sm {% if view == 'year' %}btn-primary{% else %}btn-default{% endif %}">
            <i class="ri-calendar-line"></i> Year
        </a>
    </div>

    {# Navigation #}
    <div class="d-flex ai-center gap-sm">
        {% if view == 'month' %}
            <a href="{{ path('mautic_marketing_planner_index', {view: 'month', year: prevYear, month: prevMonth}) }}" class="btn btn-default btn-sm">
                <i class="ri-arrow-left-s-line"></i>
            </a>
            <strong style="min-width:120px; text-align:center;">{{ monthName }} {{ year }}</strong>
            <a href="{{ path('mautic_marketing_planner_index', {view: 'month', year: nextYear, month: nextMonth}) }}" class="btn btn-default btn-sm">
                <i class="ri-arrow-right-s-line"></i>
            </a>
            <a href="{{ path('mautic_marketing_planner_index', {view: 'month', year: 'now'|date('Y'), month: 'now'|date('n')}) }}" class="btn btn-default btn-sm">Today</a>
        {% elseif view == 'year' %}
            <a href="{{ path('mautic_marketing_planner_index', {view: 'year', year: prevYear}) }}" class="btn btn-default btn-sm">
                <i class="ri-arrow-left-s-line"></i>
            </a>
            <strong style="min-width:60px; text-align:center;">{{ year }}</strong>
            <a href="{{ path('mautic_marketing_planner_index', {view: 'year', year: nextYear}) }}" class="btn btn-default btn-sm">
                <i class="ri-arrow-right-s-line"></i>
            </a>
        {% else %}
            <strong>All upcoming tasks</strong>
        {% endif %}
    </div>

    {# Add button #}
    <a href="{{ path('mautic_marketing_planner_new') }}" class="btn btn-primary btn-sm">
        <i class="ri-add-line"></i> Add item
    </a>
</div>

{# ── MONTH VIEW ───────────────────────────────────────────────────────────── #}
{% if view == 'month' %}
<div class="panel panel-default">
    <div class="panel-body pa-0">
        <table class="table table-bordered mb-0" style="table-layout:fixed;">
            <thead style="background:#f5f6f7;">
                <tr>
                    {% for dayName in ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'] %}
                    <th class="text-center" style="width:14.28%; padding:8px 4px; font-size:12px; font-weight:600; color:#666;">{{ dayName }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for week in calendarWeeks %}
                <tr>
                    {% for cell in week %}
                    <td style="height:110px; vertical-align:top; padding:4px; {% if not cell.day %}background:#fafafa;{% elseif cell.isPast %}background:#fdfdfd;{% endif %} {% if cell.isToday %}border-top:3px solid #4e5d6c !important;{% endif %}">
                        {% if cell.day %}
                        <div style="font-size:12px; font-weight:{% if cell.isToday %}700{% else %}400{% endif %}; color:{% if cell.isToday %}#4e5d6c{% elseif cell.isPast %}#bbb{% else %}#555{% endif %}; margin-bottom:3px;">
                            {{ cell.day }}
                        </div>
                        {% for item in cell.items %}
                        <div style="background:{% if item.doneAt %}#bbb{% else %}#4e5d6c{% endif %}; color:#fff; border-radius:3px; padding:2px 5px; margin-bottom:2px; font-size:11px; line-height:1.4; {% if item.doneAt %}text-decoration:line-through; opacity:.6;{% endif %} overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                            <a href="{{ path('mautic_marketing_planner_edit', {id: item.id}) }}" style="color:#fff; text-decoration:none;" title="{{ item.name }}">
                                {{ item.name }}
                            </a>
                        </div>
                        {% endfor %}
                        {% endif %}
                    </td>
                    {% endfor %}
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# ── YEAR VIEW ────────────────────────────────────────────────────────────── #}
{% elseif view == 'year' %}
<div class="row">
    {% for m in 1..12 %}
    {% set monthItems = itemsByMonth[m] ?? [] %}
    {% set monthDate = year ~ '-' ~ m|format_number(0) ~ '-01' %}
    <div class="col-sm-6 col-md-4 mb-md">
        <div class="panel panel-default h-100">
            <div class="panel-heading" style="background:#f5f6f7; border-bottom:2px solid {% if m == 'now'|date('n')|number_format and year == 'now'|date('Y')|number_format %}#4e5d6c{% else %}#e4e5e6{% endif %};">
                <a href="{{ path('mautic_marketing_planner_index', {view: 'month', year: year, month: m}) }}" style="color:inherit; text-decoration:none;">
                    <strong>{{ (year ~ '-' ~ '%02d'|format(m) ~ '-01')|date('F') }}</strong>
                    {% if monthItems|length > 0 %}
                    <span class="badge" style="background:#4e5d6c; float:right;">{{ monthItems|length }}</span>
                    {% endif %}
                </a>
            </div>
            <div class="panel-body pa-sm">
                {% if monthItems is empty %}
                    <p class="text-muted small mb-0">No activities planned.</p>
                {% else %}
                    {% for item in monthItems %}
                    <div class="d-flex ai-center gap-xs mb-xs" style="{% if item.doneAt %}opacity:.5;{% endif %}">
                        <span style="font-size:11px; color:#888; min-width:20px;">{{ item.deadline|date('d') }}</span>
                        <span style="flex:1; font-size:12px; {% if item.doneAt %}text-decoration:line-through;{% endif %} overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                            <a href="{{ path('mautic_marketing_planner_edit', {id: item.id}) }}" style="color:inherit;" title="{{ item.name }}">{{ item.name }}</a>
                        </span>
                        <form method="post" action="{{ path('mautic_marketing_planner_done', {id: item.id}) }}" style="margin:0;">
                            <button type="submit" class="btn btn-xs {% if item.doneAt %}btn-success{% else %}btn-default{% endif %}" title="{% if item.doneAt %}Mark undone{% else %}Mark done{% endif %}" style="padding:1px 5px;">
                                <i class="ri-check-line"></i>
                            </button>
                        </form>
                    </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </div>
    {% endfor %}
</div>

{# ── LIST VIEW ────────────────────────────────────────────────────────────── #}
{% else %}
<div class="panel panel-default">
    <div class="panel-body pa-0">
        {% if items is empty %}
        <div class="pa-lg text-center text-muted">
            <i class="ri-calendar-line" style="font-size:3rem; display:block; margin-bottom:12px;"></i>
            No planning items yet. <a href="{{ path('mautic_marketing_planner_new') }}">Add the first one →</a>
        </div>
        {% else %}
        <table class="table table-striped table-hover mb-0">
            <thead>
                <tr>
                    <th style="width:110px;">Deadline</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Assigned to</th>
                    <th style="width:100px;">Done</th>
                    <th style="width:80px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for item in items %}
                <tr style="{% if item.doneAt %}opacity:.5;{% endif %}">
                    <td style="white-space:nowrap;">
                        <span style="{% if not item.doneAt and item.deadline < today %}color:#e74c3c; font-weight:600;{% endif %}">
                            {{ item.deadline|date('d M Y') }}
                        </span>
                    </td>
                    <td style="{% if item.doneAt %}text-decoration:line-through;{% endif %}">
                        <a href="{{ path('mautic_marketing_planner_edit', {id: item.id}) }}">{{ item.name }}</a>
                    </td>
                    <td class="text-muted" style="font-size:12px; max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                        {{ item.description }}
                    </td>
                    <td style="font-size:12px;">
                        {% if item.assignedTo %}
                            {{ item.assignedTo.firstName }} {{ item.assignedTo.lastName }}
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td>
                        <form method="post" action="{{ path('mautic_marketing_planner_done', {id: item.id}) }}" style="margin:0; display:inline;">
                            <button type="submit" class="btn btn-xs {% if item.doneAt %}btn-success{% else %}btn-default{% endif %}">
                                <i class="ri-check-line"></i>
                                {% if item.doneAt %}{{ item.doneAt|date('d M') }}{% else %}Mark done{% endif %}
                            </button>
                        </form>
                    </td>
                    <td>
                        <a href="{{ path('mautic_marketing_planner_edit', {id: item.id}) }}" class="btn btn-xs btn-default" title="Edit">
                            <i class="ri-edit-line"></i>
                        </a>
                        <form method="post" action="{{ path('mautic_marketing_planner_delete', {id: item.id}) }}" style="display:inline;" onsubmit="return confirm('Delete this item?')">
                            <button type="submit" class="btn btn-xs btn-danger" title="Delete">
                                <i class="ri-delete-bin-line"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% endif %}
    </div>
</div>
{% endif %}

</div>
{% endblock %}
